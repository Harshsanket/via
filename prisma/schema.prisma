// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  //user
  id       Int    @id @default(autoincrement())
  email    String @unique
  username String
  password String

  //file-limit
  fileSizeLimit Int?
  storageUsed   Int  @default(0)

  //user-access
  accessToken         String
  refreshToken        String
  forgotPasswordToken String?

  //timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //relation
  sharedFiles SharedFile[]
}

model SharedFile {
  //file-info
  id       Int     @id @default(autoincrement())
  fileLink String  
  fileName String
  fileSize Int
  mimeType String?
  checksum String  

//file-status
  isUploadCompleted Boolean @default(false)
  downloadCount     Int     @default(0)

  shortCode String    @unique

//timestamps
  createdAt DateTime @default(now())
  expiresAt DateTime
  deletedAt DateTime?

//relation
  userId Int
  user   User @relation(fields: [userId], references: [id])
  
//attributes
  @@unique([userId, checksum])
  @@index([expiresAt])
}
